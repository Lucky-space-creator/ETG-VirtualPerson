FROM node:18-alpine AS builder
WORKDIR /app
COPY vue-admin/package.json .
COPY vue-admin/package-lock.json* .
RUN npm install
COPY vue-admin/ .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY vue-admin/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
